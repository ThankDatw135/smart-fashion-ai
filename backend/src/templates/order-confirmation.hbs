<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Xác nhận đơn hàng — Smart Fashion AI</title>
</head>
<body style="margin:0; padding:0; background-color:#f5f5f5; font-family: 'Segoe UI', Arial, sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="padding: 40px 20px;">
    <tr>
      <td align="center">
        <table width="520" cellpadding="0" cellspacing="0" style="background:#ffffff; border-radius:12px; box-shadow: 0 2px 8px rgba(0,0,0,0.08);">
          <!-- Header -->
          <tr>
            <td style="padding: 32px; text-align:center; background: linear-gradient(135deg, #10b981 0%, #059669 100%); border-radius: 12px 12px 0 0;">
              <h1 style="margin:0; font-size:26px; color:#ffffff;">✅ Đặt hàng thành công!</h1>
              <p style="margin:8px 0 0; color:rgba(255,255,255,0.9); font-size:14px;">
                Mã đơn: <strong>{{orderNumber}}</strong>
              </p>
            </td>
          </tr>
          <!-- Content -->
          <tr>
            <td style="padding: 32px;">
              <p style="margin:0 0 16px; color:#333; line-height:1.6; font-size:15px;">
                Xin chào <strong>{{fullName}}</strong>,
              </p>
              <p style="margin:0 0 24px; color:#666; line-height:1.6; font-size:14px;">
                Cảm ơn bạn đã đặt hàng tại Smart Fashion AI. Đơn hàng của bạn đã được ghi nhận và đang chờ xử lý.
              </p>

              <!-- Order Items -->
              <table width="100%" cellpadding="8" cellspacing="0" style="margin:0 0 24px; border:1px solid #eee; border-radius:8px; border-collapse:collapse;">
                <tr style="background:#f8f9fa;">
                  <th style="text-align:left; color:#555; font-size:13px; border-bottom:1px solid #eee;">Sản phẩm</th>
                  <th style="text-align:center; color:#555; font-size:13px; border-bottom:1px solid #eee;">SL</th>
                  <th style="text-align:right; color:#555; font-size:13px; border-bottom:1px solid #eee;">Giá</th>
                </tr>
                {{#each items}}
                <tr>
                  <td style="font-size:14px; color:#333; border-bottom:1px solid #f0f0f0;">
                    {{this.productName}}<br>
                    <span style="color:#999; font-size:12px;">{{this.variantInfo}}</span>
                  </td>
                  <td style="text-align:center; font-size:14px; color:#333; border-bottom:1px solid #f0f0f0;">×{{this.quantity}}</td>
                  <td style="text-align:right; font-size:14px; color:#333; border-bottom:1px solid #f0f0f0;">{{this.subtotal}}đ</td>
                </tr>
                {{/each}}
              </table>

              <!-- Totals -->
              <table width="100%" cellpadding="4" cellspacing="0" style="margin:0 0 24px;">
                <tr>
                  <td style="font-size:14px; color:#666;">Tạm tính:</td>
                  <td style="text-align:right; font-size:14px; color:#333;">{{subtotal}}đ</td>
                </tr>
                <tr>
                  <td style="font-size:14px; color:#666;">Phí vận chuyển:</td>
                  <td style="text-align:right; font-size:14px; color:#333;">{{shippingFee}}đ</td>
                </tr>
                {{#if discount}}
                <tr>
                  <td style="font-size:14px; color:#10b981;">Giảm giá:</td>
                  <td style="text-align:right; font-size:14px; color:#10b981;">-{{discount}}đ</td>
                </tr>
                {{/if}}
                <tr>
                  <td style="font-size:16px; color:#333; font-weight:bold; border-top:2px solid #333; padding-top:8px;">Tổng cộng:</td>
                  <td style="text-align:right; font-size:16px; color:#333; font-weight:bold; border-top:2px solid #333; padding-top:8px;">{{total}}đ</td>
                </tr>
              </table>

              <!-- Shipping Info -->
              <div style="background:#f8f9fa; border-radius:8px; padding:16px; margin:0 0 24px;">
                <p style="margin:0 0 8px; font-size:14px; color:#333; font-weight:bold;">📦 Thông tin giao hàng</p>
                <p style="margin:0; font-size:13px; color:#666; line-height:1.8;">
                  {{shippingName}} — {{shippingPhone}}<br>
                  {{shippingAddress}}, {{shippingWard}}, {{shippingDistrict}}, {{shippingProvince}}
                </p>
              </div>

              <!-- CTA -->
              <div style="text-align:center; margin:24px 0;">
                <a href="{{frontendUrl}}/user/orders" style="display:inline-block; background:#4361ee; color:#fff; text-decoration:none; padding:14px 36px; border-radius:8px; font-weight:bold; font-size:15px;">
                  Theo dõi đơn hàng →
                </a>
              </div>
            </td>
          </tr>
          <!-- Footer -->
          <tr>
            <td style="padding: 16px 32px 32px; border-top: 1px solid #eee;">
              <p style="margin:0; color:#999; font-size:12px; text-align:center;">
                © 2026 Smart Fashion AI — Thời trang thông minh, phù hợp với bạn.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>

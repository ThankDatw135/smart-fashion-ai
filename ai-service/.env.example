# ─── App ───
DEBUG=true
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# ─── Database (khớp với docker/.env) ───
DATABASE_URL=postgresql+asyncpg://smartfashion:smartfashion_secret@localhost:5432/smartfashion_db

# ─── Redis (khớp với docker/.env) ───
REDIS_URL=redis://:smartfashion_redis@localhost:6379/1

# ─── RabbitMQ (khớp với docker/.env) ───
RABBITMQ_URL=amqp://smartfashion:smartfashion_rabbit@localhost:5672/smartfashion

# ─── Google Gemini ───
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─── Embedding ───
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ─── Backend API ───
BACKEND_API_URL=http://localhost:4000/api/v1

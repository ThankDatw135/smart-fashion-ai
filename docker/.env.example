# ========================================
# Smart Fashion AI — Docker Environment Variables
# ========================================
# Copy file này thành .env rồi điều chỉnh giá trị phù hợp:
#   cp docker/.env.example docker/.env
# ========================================

# --- PostgreSQL ---
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=smartfashion_db
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PASSWORD=your_redis_password
REDIS_PORT=6379

# --- RabbitMQ ---
RABBITMQ_USER=your_rabbitmq_user
RABBITMQ_PASSWORD=your_rabbitmq_password
RABBITMQ_VHOST=smartfashion
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672


# ====================================
# Smart Fashion AI — Backend Environment
# Copy file này thành .env trước khi chạy
# ====================================

# --- Ứng dụng ---
APP_NAME=SmartFashionAI
APP_PORT=4000
APP_ENV=development
API_PREFIX=api
API_VERSION=1

# --- Cơ sở dữ liệu PostgreSQL ---
DATABASE_URL=postgresql://your_db_user:your_db_password@localhost:5432/smartfashion_db?schema=public

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_if_any
REDIS_DB=0

# --- RabbitMQ ---
RABBITMQ_URL=amqp://your_rabbitmq_user:your_rabbitmq_password@localhost:5672
RABBITMQ_QUEUE_PREFIX=sf

# --- JWT (RS256) ---
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# --- Email (SMTP) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email_address@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_FROM=noreply@smartfashion.vn

# --- Cloudinary (Production) ---
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
UPLOAD_DRIVER=local

# --- MoMo Payment (Sandbox) ---
MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_IPN_URL=http://localhost:4000/api/v1/payments/momo/ipn
MOMO_REDIRECT_URL=http://localhost:3000/checkout/success

# --- Frontend URL (CORS) ---
FRONTEND_URL=http://localhost:3000

# --- Throttle (Rate Limiting) ---
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
